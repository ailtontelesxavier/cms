# App
APP_NAME="CMS Backend"
APP_VERSION="0.1.0"
DEBUG=false
SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=7

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cms

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=cms

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin123
MINIO_SECRET_KEY=admin123
MINIO_BUCKET=cms-images
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000/cms-images
